# ImobiPro - Template de variáveis de ambiente
# Copie este arquivo como .env e preencha os valores corretos para cada ambiente
#
# Em desenvolvimento:  FLASK_ENV=development
# Em produção:         FLASK_ENV=production

FLASK_ENV=development

# Chave secreta para criptografar sessões
# Em produção: gere uma chave forte com o comando:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-por-uma-chave-forte

# Caminho do banco de dados
# Em desenvolvimento:  database/imobipro.db   (relativo ao projeto)
# Em produção:         /var/www/imobipro/database/imobipro.db  (absoluto)
DATABASE_PATH=database/imobipro.db
